# Server Configuration
# Set to 'true' when running server locally to skip Firebase writes
# This prevents duplicate data when both local and remote servers are running
IS_LOCAL=false
SERVER_URL=http://localhost:4000

# MQTT Configuration (optional - defaults shown)
# MQTT_BROKER=mqtt://public.cloud.shiftr.io:1883
# MQTT_USER=public
# MQTT_PASS=public

# Port (optional - defaults to 4000)
# PORT=4000
