# Server Configuration
REACT_APP_SERVER_URL=http://localhost:4000

# Firebase Admin for local server access
# Use one of these so local Node reads/writes are not blocked by RTDB rules:
# 1. Put a JSON file at one of these default paths:
#    ./service-account.json
#    ./firebase-service-account.json
#    ./serviceAccountKey.json
# 2. Or set one of these env vars:
# FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# FIREBASE_DATABASE_URL=https://magic-wand-conndev-default-rtdb.firebaseio.com

# MQTT Configuration (optional - defaults shown)
# MQTT_BROKER=mqtt://public.cloud.shiftr.io:1883
# MQTT_USER=public
# MQTT_PASS=public

# Port (optional - defaults to 4000)
# PORT=4000
